[Unit]
Description=cucu-device NFC reader
After=network.target

[Service]
Type=simple
User=davidedorigatti
Environment=XDG_RUNTIME_DIR=/run/user/__DEPLOY_UID__ TERM=linux
ExecStart=/usr/bin/python3 -u /home/davidedorigatti/cucu-device/read_nfc.py
WorkingDirectory=/home/davidedorigatti/cucu-device
StandardOutput=journal
StandardError=journal
Restart=always
RestartSec=1

[Install]
WantedBy=multi-user.target
